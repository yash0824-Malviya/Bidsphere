# ── Development (Vite dev proxy) ─────────────────────────────────────────────
# Where the Vite dev server forwards /api/* requests.
# Defaults to http://localhost:8081 when unset.
VITE_PROXY_TARGET=http://localhost:8081

# Alias for VITE_PROXY_TARGET (same purpose).
# VITE_ERPNEXT_URL=http://localhost:8081

# ── Production (Vercel serverless proxy: api/[...path].ts) ───────────────────
# Required on Vercel — NOT exposed to the browser.
ERPNEXT_URL=https://buddy-therapeutic-saver-preferences.trycloudflare.com

# ERPNext API credentials — injected server-side by the dev proxy and the
# Vercel function. NEVER bundled into the client.
ERP_API_KEY=
ERP_API_SECRET=

# Legacy aliases (used if ERP_* vars are unset):
# VITE_API_KEY=
# VITE_API_SECRET=

# ── Client-side (safe to prefix with VITE_) ──────────────────────────────────
VITE_COMPANY=Netlink
VITE_DEFAULT_CURRENCY=USD
VITE_BUYING_PRICE_LIST=Standard Buying

# Anthropic Claude — browser-side only; do not use in public production.
VITE_ANTHROPIC_API_KEY=
# Anthropic model id. Optional — defaults to claude-sonnet-4-5-20250929.
VITE_ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# OpenAI — fallback when Claude is overloaded or unavailable.
VITE_OPENAI_API_KEY=
VITE_OPENAI_MODEL=gpt-4o-mini

# ── Role users (Netlink Procurement RBAC — provision with: node scripts/provision-role-users.mjs)
# procurement@netlink.com  → Procurement Manager
# finance@netlink.com      → Finance (payments, budget)
# warehouse@netlink.com    → Warehouse (GRN, invoices, inventory)
# admin@netlink.com        → Full access
# Default password when provisioning: Netlink@2026 (override with ROLE_USER_PASSWORD)
